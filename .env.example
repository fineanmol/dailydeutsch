# ── Translation APIs ────────────────────────────────────────────
# DeepL — get a free key at https://www.deepl.com/pro-api
# Free keys end with :fx   e.g.  abc123:fx
DEEPL_KEY=

# Google Translate — get a key at https://console.cloud.google.com
GOOGLE_KEY=

# Preferred provider: auto | deepl | google | mymemory
TRANSLATION_PROVIDER=auto

# ── Firebase ─────────────────────────────────────────────────────
# Create a project at https://console.firebase.google.com
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# ── AI (Gemini) ──────────────────────────────────────────────────
# Server-side Gemini key — powers the free AI trial via /api/gemini.
# NEVER ship this to the browser. (Falls back to GOOGLE_KEY if unset.)
GEMINI_KEY=

# Free AI trial calls allowed per signed-in user (server-metered)
TRIAL_LIMIT=3
# Max requests per minute per user/IP on the API proxy
RATE_MAX_PER_MIN=20

# ── Server ───────────────────────────────────────────────────────
PORT=3000
