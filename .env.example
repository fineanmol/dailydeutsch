# ── Translation APIs ────────────────────────────────────────────
# DeepL — get a free key at https://www.deepl.com/pro-api
# Free keys end with :fx   e.g.  abc123:fx
DEEPL_KEY=

# Google Translate — get a key at https://console.cloud.google.com
GOOGLE_KEY=

# Preferred provider: auto | deepl | google | mymemory
TRANSLATION_PROVIDER=auto

# ── Firebase ─────────────────────────────────────────────────────
# Create a project at https://console.firebase.google.com
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# ── Server ───────────────────────────────────────────────────────
PORT=3000
