rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // XP cap: ~50 actions/day * ~30 XP * 365 days * 5 years ≈ 2.7M. A
    // 5,000,000 ceiling leaves generous headroom for legitimate long-term
    // users while making an obviously-forged score (e.g. 9,999,999)
    // impossible to write.
    function validProfile(d) {
      return d.xp is int      && d.xp >= 0      && d.xp <= 5000000
          && d.level is int   && d.level >= 1   && d.level <= 250
          && d.streak is int  && d.streak >= 0  && d.streak <= 3650
          && d.name is string && d.name.size() <= 60
          && d.uid is string  && d.uid == request.auth.uid;
    }

    // ── Private user data (words, history, stats, settings) ──────
    // Fully owner-scoped. This is the authoritative store; the public
    // profile below is a denormalized, validated projection of it.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Public user profiles (live leaderboard) ──────────────────
    match /profiles/{profileId} {

      // Anyone signed in can read the leaderboard.
      allow read: if request.auth != null;

      // Owner-only writes, with strict validation so a client cannot
      // forge arbitrary XP/level/streak to top the board. These bounds
      // are not a substitute for server-authoritative scoring, but they
      // stop trivial console tampering (e.g. xp: 9999999).
      allow write: if request.auth != null
        && request.auth.uid == profileId
        && validProfile(request.resource.data);
    }

    // ── Waitlist (Pro interest signals) ──────────────────────────
    // Create-only, with a shape + size guard.
    match /waitlist/{docId} {
      allow create: if request.auth != null
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 254;
      allow read, update, delete: if false;
    }

    // ── Free AI trial (no backend; quota-protected via rules) ─────
    // Lifetime cap of TRIAL_LIMIT AI calls per signed-in account, tracked
    // in trialUsage/{uid}. This collection is deliberately TOP-LEVEL (not
    // under /users/**) so the strict guards below actually apply — the
    // owner-wide /users rule would otherwise allow arbitrary writes.
    function trialLimit() { return 5; }

    // Per-account cap on shared-key (paid-tier) translations. Protects the
    // shared Google Translate quota/budget the same way trialLimit protects
    // Gemini. Bump this (and redeploy) as pricing/usage evolves.
    function translateLimit() { return 200; }

    // Whether the signed-in user is entitled to the paid-tier translator
    // (shared Google key). The flag lives in entitlements/{uid}, which is
    // ADMIN-WRITE-ONLY below, so a user cannot grant themselves access.
    function translateEntitled() {
      return request.auth != null
        && exists(/databases/$(database)/documents/entitlements/$(request.auth.uid))
        && get(/databases/$(database)/documents/entitlements/$(request.auth.uid)).data.translateEnabled == true;
    }

    match /trialUsage/{uid} {
      // A user may only see their own usage.
      allow read: if request.auth != null && request.auth.uid == uid;

      // First call: create the counter at exactly 1.
      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.count == 1
        && request.resource.data.keys().hasOnly(['count', 'updatedAt']);

      // Subsequent calls: count may ONLY increase by exactly 1, and never
      // beyond the cap. No resets, no jumps, no decrements — so clearing
      // localStorage or re-creating the doc can't restore trials.
      allow update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.count == resource.data.count + 1
        && request.resource.data.count <= trialLimit()
        && request.resource.data.keys().hasOnly(['count', 'updatedAt']);

      allow delete: if false;
    }

    // ── Paid-tier translator usage (shared Google key) ───────────
    // Same increment-only, capped, no-reset shape as trialUsage. Only a
    // translate-entitled user may create/grow their counter, and only up to
    // translateLimit(). Top-level (not under /users/**) so guards apply.
    match /translateUsage/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;

      allow create: if request.auth != null
        && request.auth.uid == uid
        && translateEntitled()
        && request.resource.data.count == 1
        && request.resource.data.keys().hasOnly(['count', 'updatedAt']);

      allow update: if request.auth != null
        && request.auth.uid == uid
        && translateEntitled()
        && request.resource.data.count == resource.data.count + 1
        && request.resource.data.count <= translateLimit()
        && request.resource.data.keys().hasOnly(['count', 'updatedAt']);

      allow delete: if false;
    }

    // ── Entitlements (paid-tier flags) — admin-managed only ───────
    // A user may READ their own entitlement (so the client knows whether to
    // offer the paid translator), but NEVER write it. You set
    // entitlements/{uid} = { translateEnabled: true } manually in the
    // Firebase console (or via an admin SDK) for paying users.
    match /entitlements/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // The shared config doc holding the Gemini trial key (field `key`) and
    // the shared translator key (field `GOOGLE_KEY`). Readable by a signed-in
    // user who EITHER still has Gemini trial budget left, OR is translate-
    // entitled and under the translate cap. Never writable from clients — it
    // is seeded once via the Firebase console / admin.
    match /config/trial {
      allow read: if request.auth != null
        && (
          (
            exists(/databases/$(database)/documents/trialUsage/$(request.auth.uid))
            && get(/databases/$(database)/documents/trialUsage/$(request.auth.uid)).data.count <= trialLimit()
          )
          ||
          (
            translateEntitled()
            && exists(/databases/$(database)/documents/translateUsage/$(request.auth.uid))
            && get(/databases/$(database)/documents/translateUsage/$(request.auth.uid)).data.count <= translateLimit()
          )
        );
      allow write: if false;
    }
  }
}
